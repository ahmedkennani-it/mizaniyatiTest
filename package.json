{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "web": "expo start --web",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "typecheck": "node --stack-size=8000 ./node_modules/typescript/lib/tsc.js --noEmit",
    "lint": "eslint .",
    "test": "jest",
    "test:ci": "jest --ci --runInBand"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "@testing-library/react-native",
      "<rootDir>/jest/setupTests.js"
    ],
    "moduleNameMapper": {
      "^\\./intlPolyfills$": "<rootDir>/jest/intlPolyfillsMock.js",
      "^lucide-react-native$": "<rootDir>/jest/lucideMock.jsx",
      "^expo-linear-gradient$": "<rootDir>/jest/linearGradientMock.jsx",
      "^react-native-safe-area-context$": "<rootDir>/jest/safeAreaContextMock.jsx",
      "^expo-speech-recognition$": "<rootDir>/jest/speechRecognitionMock.js"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|i18next|react-i18next))"
    ]
  },
  "dependencies": {
    "@expo-google-fonts/ibm-plex-sans-arabic": "^0.4.2",
    "@expo-google-fonts/outfit": "^0.4.3",
    "@formatjs/intl-getcanonicallocales": "^3.2.11",
    "@formatjs/intl-locale": "^5.3.10",
    "@formatjs/intl-pluralrules": "^6.3.13",
    "@formatjs/intl-relativetimeformat": "^12.3.13",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/native": "^7.1.17",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.13",
    "expo-crypto": "~15.0.9",
    "expo-linear-gradient": "~15.0.8",
    "expo-local-authentication": "~17.0.8",
    "expo-localization": "~17.0.9",
    "expo-notifications": "~0.32.17",
    "expo-secure-store": "~15.0.8",
    "expo-speech-recognition": "^3.1.3",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.18",
    "i18next": "^26.3.4",
    "lucide-react-native": "^0.511.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^26.1.1",
    "@types/react": "~19.1.10",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.8",
    "prettier": "^3.9.4",
    "typescript": "~5.9.2"
  }
}
